---
import { Menu, Moon, Sun, X } from "@lucide/astro";

interface Props {
  caseStudy?: boolean;
}

const { caseStudy = false } = Astro.props;
const links = caseStudy
  ? [
      ["Home", "/"],
      ["Architecture", "#architecture"],
      ["Proof", "#proof"],
      ["GitHub", "https://github.com/Kuronashiro/salesops-ai"]
    ]
  : [
      ["Experience", "#experience"],
      ["Projects", "#projects"],
      ["Skills", "#skills"],
      ["Contact", "#contact"]
    ];
---

<header class="site-header">
  <a class="brand" href={caseStudy ? "/" : "#top"} aria-label="Muhammad Irham Rizq home">
    <img src="/assets/kuronashiro-avatar.png" alt="" />
    <span>Irham Rizq</span>
  </a>

  <nav class="site-nav" id="site-navigation" aria-label="Primary navigation">
    {links.map(([label, href]) => <a href={href}>{label}</a>)}
    <div class="language-switcher" role="group" aria-label="Language">
      <button type="button" data-language="en" aria-pressed="true">EN</button>
      <button type="button" data-language="zh" aria-pressed="false">CN</button>
      <button type="button" data-language="id" aria-pressed="false">ID</button>
    </div>
  </nav>

  <div class="header-controls">
    <button
      class="theme-toggle"
      type="button"
      aria-label="Switch to dark mode"
      aria-pressed="false"
      title="Change color theme"
    >
      <Moon class="theme-icon theme-icon-moon" size={19} aria-hidden="true" />
      <Sun class="theme-icon theme-icon-sun" size={19} aria-hidden="true" />
      <span class="theme-label">Dark Mode</span>
    </button>
    <button
      class="menu-toggle"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="site-navigation"
      title="Navigation menu"
    >
      <Menu class="menu-icon menu-icon-open" size={22} aria-hidden="true" />
      <X class="menu-icon menu-icon-close" size={22} aria-hidden="true" />
    </button>
  </div>
</header>

<script>
  import {
    defaultLocale,
    isLocale,
    localeLanguageTags,
    translate,
    translations,
    type Locale
  } from "../i18n/translations";

  type PortfolioWindow = Window & {
    portfolioLocale?: Locale;
    portfolioTranslate?: (source: string) => string;
  };

  type TextRecord = {
    node: Text;
    prefix: string;
    source: string;
    suffix: string;
  };

  type AttributeRecord = {
    element: Element;
    name: string;
    source: string;
  };

  const portfolioWindow = window as PortfolioWindow;
  const normalizeText = (value: string) => value.trim().replace(/\s+/g, " ");
  const hasTranslation = (source: string) =>
    source in translations.id || source in translations.zh;
  const textRecords: TextRecord[] = [];
  const attributeRecords: AttributeRecord[] = [];
  const textWalker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);

  let currentTextNode = textWalker.nextNode();
  while (currentTextNode) {
    const node = currentTextNode as Text;
    const parent = node.parentElement;
    const value = node.nodeValue ?? "";
    const source = normalizeText(value);

    if (
      parent &&
      source &&
      !parent.closest("script, style, noscript, code, pre, [data-i18n-ignore]") &&
      hasTranslation(source)
    ) {
      const parts = value.match(/^(\s*)([\s\S]*?)(\s*)$/);
      textRecords.push({
        node,
        prefix: parts?.[1] ?? "",
        source,
        suffix: parts?.[3] ?? ""
      });
    }

    currentTextNode = textWalker.nextNode();
  }

  const translatedAttributes = ["alt", "aria-label", "data-short", "title"];
  document.querySelectorAll("*").forEach((element) => {
    translatedAttributes.forEach((name) => {
      const value = element.getAttribute(name);
      const source = value ? normalizeText(value) : "";
      if (source && hasTranslation(source)) {
        attributeRecords.push({ element, name, source });
      }
    });
  });

  const languageButtons = document.querySelectorAll<HTMLButtonElement>("[data-language]");
  const originalTitle = document.title;
  const applyLocale = (locale: Locale) => {
    portfolioWindow.portfolioLocale = locale;
    portfolioWindow.portfolioTranslate = (source) => translate(locale, source);
    document.documentElement.lang = localeLanguageTags[locale];
    document.documentElement.dataset.locale = locale;

    textRecords.forEach(({ node, prefix, source, suffix }) => {
      node.nodeValue = `${prefix}${translate(locale, source)}${suffix}`;
    });
    attributeRecords.forEach(({ element, name, source }) => {
      element.setAttribute(name, translate(locale, source));
    });
    languageButtons.forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.language === locale));
    });

    document.title = translate(locale, originalTitle);
    localStorage.setItem("portfolio-locale", locale);
    localStorage.setItem("portfolio-locale-version", "2");
    window.dispatchEvent(new CustomEvent("portfolio:localechange", { detail: { locale } }));
  };

  const t = (source: string) => portfolioWindow.portfolioTranslate?.(source) ?? source;
  const themeToggle = document.querySelector(".theme-toggle");
  const themeLabel = themeToggle?.querySelector(".theme-label");
  const savedTheme = localStorage.getItem("portfolio-theme");

  const syncThemeControl = () => {
    const isDark = document.documentElement.dataset.theme === "dark";
    themeToggle?.setAttribute("aria-pressed", isDark ? "true" : "false");
    themeToggle?.setAttribute(
      "aria-label",
      t(isDark ? "Switch to light mode" : "Switch to dark mode")
    );
    if (themeLabel) themeLabel.textContent = t(isDark ? "Light Mode" : "Dark Mode");
  };

  if (savedTheme === "dark") {
    document.documentElement.dataset.theme = "dark";
  }
  syncThemeControl();

  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.dataset.theme === "dark";
    document.documentElement.dataset.theme = isDark ? "" : "dark";
    localStorage.setItem("portfolio-theme", isDark ? "light" : "dark");
    syncThemeControl();
  });

  const menuToggle = document.querySelector(".menu-toggle");
  const siteNav = document.querySelector(".site-nav");
  const siteHeader = document.querySelector(".site-header");

  const closeMenu = () => {
    siteNav?.classList.remove("is-open");
    menuToggle?.setAttribute("aria-expanded", "false");
    menuToggle?.setAttribute("aria-label", t("Open navigation menu"));
  };

  menuToggle?.addEventListener("click", () => {
    const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
    siteNav?.classList.toggle("is-open", !isOpen);
    menuToggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
    menuToggle.setAttribute(
      "aria-label",
      t(isOpen ? "Open navigation menu" : "Close navigation menu")
    );
  });

  languageButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const locale = button.dataset.language;
      if (isLocale(locale ?? null)) {
        applyLocale(locale);
        syncThemeControl();
        closeMenu();
      }
    });
  });

  siteNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeMenu();
  });

  document.addEventListener("click", (event) => {
    if (event.target instanceof Node && !siteHeader?.contains(event.target)) {
      closeMenu();
    }
  });

  window.matchMedia("(min-width: 681px)").addEventListener("change", closeMenu);

  const savedLocale = localStorage.getItem("portfolio-locale");
  const hasCurrentLocalePreference = localStorage.getItem("portfolio-locale-version") === "2";
  applyLocale(hasCurrentLocalePreference && isLocale(savedLocale) ? savedLocale : defaultLocale);
  syncThemeControl();
</script>
