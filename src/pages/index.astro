              Learning HTML, CSS, JavaScript, C, Python, MySQL, Java, Kotlin,
              NestJS, and Next.js.
            </li>
            <li>
              Active in HIMTI and Vice Chairman in BINUSIAN GAMING Bandung.
            </li>
          </ul>
        </article>
      </section>

      <section class="stats-band reveal" aria-label="Portfolio highlights">
        {stats.map(([value, label]) => (
          <div>
            <strong>{value}</strong>
            <span>{label}</span>
          </div>
        ))}
      </section>

      <section class="case-study reveal" aria-labelledby="case-title">
        <div class="case-copy">
          <p class="section-kicker">Featured Case Study</p>
          <h2 id="case-title">{featuredCase.name}</h2>
          <p>{featuredCase.description}</p>
          <div class="case-actions">
            <a class="button primary" href="/projects/salesops-ai">Read Case Study</a>
            <a class="button secondary dark" href={featuredCase.repo}>Open GitHub Repo</a>
            <a class="button secondary dark" href="#projects">See All Projects</a>
          </div>
        </div>
        <div class="case-panel">
          <div class="dashboard-preview" aria-label="SalesOps dashboard preview">
            <div class="preview-window-bar">
              <span></span>
              <span></span>
              <span></span>
              <strong>salesops.local</strong>
            </div>
            <div class="dashboard-shell">
              <aside>
                <b>SalesOps</b>
                <span>Overview</span>
                <span>Transactions</span>
                <span>AI Detection</span>
                <span>Audit Logs</span>
              </aside>
              <div class="dashboard-main">
                <div class="mini-kpis">
                  <div><strong>437</strong><span>Transactions</span></div>
                  <div><strong>IDR</strong><span>Revenue</span></div>
                  <div><strong>21</strong><span>Anomalies</span></div>
                </div>
                <div class="mini-chart">
                  <i style="height: 34%"></i>
                  <i style="height: 56%"></i>
                  <i style="height: 42%"></i>
                  <i style="height: 76%"></i>
                  <i style="height: 62%"></i>
                  <i style="height: 88%"></i>
                </div>
                <div class="mini-table">
                  <span></span><span></span><span></span>
                  <span></span><span></span><span></span>
                  <span></span><span></span><span></span>
                </div>
              </div>
            </div>
          </div>
          <p>{featuredCase.status}</p>
          <div class="case-metrics">
            {featuredCase.metrics.map(([value, label]) => (
              <div>
                <strong>{value}</strong>
                <span>{label}</span>
              </div>
            ))}
          </div>
          <ul class="detail-list">
            {featuredCase.highlights.map((highlight) => <li>{highlight}</li>)}
          </ul>
          <div class="repo-paths" aria-label="Important repository paths">
            {featuredCase.repoFiles.map((file) => <code>{file}</code>)}
          </div>
        </div>
      </section>

      <section class="snapshots reveal" aria-labelledby="snapshot-title">
        <div class="section-heading">
          <p class="section-kicker">Preview</p>
          <h2 id="snapshot-title">What the main project feels like in use.</h2>
        </div>
        <div class="snapshot-grid">
          {demoSnapshots.map((snapshot) => (
            <article>
              <span>{snapshot.label}</span>
              <h3>{snapshot.title}</h3>
              <p>{snapshot.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="architecture reveal" aria-labelledby="architecture-title">
        <div class="section-heading">
          <p class="section-kicker">System Architecture</p>
          <h2 id="architecture-title">How the SalesOps AI stack moves data.</h2>
        </div>
        <div class="architecture-flow" aria-label="SalesOps AI architecture flow">
          {architectureSteps.map((step, index) => (
            <article class="architecture-node" style={`--step: ${index}`}>
              <span>{step.type}</span>
              <h3>{step.name}</h3>
              <p>{step.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="tech-stack-wall reveal" aria-labelledby="stack-title">
        <div class="section-heading">
          <p class="section-kicker">Tech Stack</p>
          <h2 id="stack-title">A GitHub-style wall of tools I work with.</h2>
        </div>
        <div class="stack-groups">
