<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Muhammad Irham Rizq portfolio - Backend and DevOps developer, BINUS Computer Science student, building reliable backend systems, deployment workflows, payment infrastructure, and SalesOps AI."
    />
    <meta name="theme-color" content="#183f2b" />
    <meta property="og:title" content="Muhammad Irham Rizq | Backend & DevOps Portfolio" />
    <meta
      property="og:description"
      content="Portfolio of Muhammad Irham Rizq: backend engineering, DevOps, SalesOps AI, payment infrastructure, community leadership, and technical projects."
    />
    <meta property="og:image" content="/assets/kuronashiro-header.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/assets/kuronashiro-avatar.png" />
    <title>Muhammad Irham Rizq | Portfolio</title>
  </head>
  <body>
    <SiteHeader />

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <img class="hero-bg" src="/assets/kuronashiro-header.jpg" alt="" />
        <div class="hero-shade"></div>
        <div class="hero-content">
          <h1 id="hero-title">Muhammad Irham Rizq</h1>
          <p class="hero-role">Backend & DevOps Developer | Payment & Escrow Systems</p>
          <p class="hero-copy">
            <span class="hero-copy-desktop">
              Undergraduate Computer Science student at Bina Nusantara University
              (BINUS), building reliable backend systems, deployment workflows,
              and payment infrastructure for digital products.
            </span>
            <span class="hero-copy-mobile">
              BINUS Computer Science student building backend systems, deployment
              workflows, and reliable digital products.
            </span>
          </p>
          <div class="role-row" aria-label="Portfolio focus areas">
            {roles.map((role) => <span data-short={role.short}>{role.label}</span>)}
          </div>
          <div class="contact-line" aria-label="Contact links">
            <a href={contact.whatsapp}>{contact.whatsappLabel}</a>
            <a href={`mailto:${contact.email}`}>{contact.email}</a>
            <a href={contact.linkedin}>{contact.linkedinLabel}</a>
            <a href={contact.github}>{contact.githubLabel}</a>
            <a href={contact.gitlab}>{contact.gitlabLabel}</a>
          </div>
          <div class="mobile-socials" aria-label="Quick contact links">
            <a href={`mailto:${contact.email}`} aria-label="Email" title="Email">
              <Mail size={20} aria-hidden="true" />
            </a>
            <a href={contact.linkedin} aria-label="LinkedIn" title="LinkedIn">
              <BriefcaseBusiness size={20} aria-hidden="true" />
            </a>
            <a href={contact.github} aria-label="GitHub" title="GitHub">
              <Code size={20} aria-hidden="true" />
            </a>
            <a href={contact.whatsapp} aria-label="WhatsApp" title="WhatsApp">
              <MessageCircle size={20} aria-hidden="true" />
            </a>
          </div>
          <div class="hero-actions">
            <a class="button primary" href="#projects">View Projects</a>
            <a class="button secondary" href={contact.cv}>
              <FileText class="button-icon" size={18} aria-hidden="true" />
              <span class="cv-label-desktop">Open CV</span>
              <span class="cv-label-mobile">CV</span>
            </a>
          </div>
        </div>
      </section>

      <section class="intro section-grid reveal" aria-labelledby="about-title">
        <div>
          <p class="section-kicker">Summary</p>
          <h2 id="about-title">A builder, organizer, and problem solver.</h2>
        </div>
        <div class="intro-copy">
          <p>
            Born in Martapura, Kalimantan on 30 July 2004, I am a dedicated
            undergraduate student with a passion for growing intermediate skills
            in web development, application development, UI/UX, and event
            coordination. I work well in collaborative environments, adapt to
            change, and bring a problem-solving mindset to technical and
            community work.
          </p>
          <div class="code-note" aria-label="Personal profile snippet">
            <span>const irham = &#123;</span>
            <span>&nbsp;&nbsp;focus: ["web", "mobile", "uiux", "events"],</span>
            <span>&nbsp;&nbsp;mindset: "persistent, adaptable, cooperative"</span>
            <span>&#125;;</span>
          </div>
        </div>
      </section>

      <section class="education section-grid reveal" aria-labelledby="education-title">
        <div>
          <p class="section-kicker">Education</p>
          <h2 id="education-title">BINUS University, Computer Science.</h2>
        </div>
        <article class="education-card">
          <div class="item-head">
            <div>
              <p>Bina Nusantara University</p>
              <h3>Computer Science</h3>
            </div>
            <time>Aug 2023 - 2027</time>
          </div>
          <p class="education-interest">
            Interest in: Web Developer, App Developer, UI/UX, Design
          </p>
          <ul class="detail-list">
