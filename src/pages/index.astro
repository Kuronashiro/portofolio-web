              data-categories={project.categories.join(" ")}
            >
              <div class:list={["project-preview", `preview-${project.preview}`]} aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
                <i></i>
              </div>
              <p>{project.course}</p>
              <h3>{project.name}</h3>
              <div class="project-meta">
                <span>{project.semester}</span>
                <span>{project.grade}</span>
              </div>
              <p>{project.body}</p>
              {project.featured && <a class="project-link" href="/projects/salesops-ai">Read case study</a>}
              {project.repo && <a class="project-link" href={project.repo}>View repository</a>}
            </article>
          ))}
        </div>
      </section>

      <section class="skills-section section-grid reveal" id="skills" aria-labelledby="skills-title">
        <div>
          <p class="section-kicker">Additional Information</p>
          <h2 id="skills-title">Certificates, skills, and languages.</h2>
        </div>
        <div class="info-grid">
          <article>
            <h3>E-Certificates / Awards</h3>
            <ul class="detail-list">
              {certificates.map((certificate) => <li>{certificate}</li>)}
            </ul>
          </article>
          <article>
            <h3>Hard Skills</h3>
            <div class="skill-cloud">
              {hardSkills.map((skill) => <span>{skill}</span>)}
            </div>
          </article>
          <article>
            <h3>Soft Skills</h3>
            <div class="skill-cloud">
              {softSkills.map((skill) => <span>{skill}</span>)}
            </div>
          </article>
          <article>
            <h3>Languages</h3>
            <p><strong>Indonesian:</strong> Full professional proficiency</p>
            <p><strong>English:</strong> Limited working proficiency</p>
          </article>
        </div>
      </section>

      <section class="contact reveal" id="contact" aria-labelledby="contact-title">
        <p class="section-kicker">Contact</p>
        <h2 id="contact-title">Let us build something useful and lively.</h2>
        <div class="contact-actions">
          <a class="button primary" href={`mailto:${contact.email}`}>Email</a>
          <a class="button secondary" href={contact.linkedin}>LinkedIn</a>
          <a class="button secondary" href={contact.whatsapp}>WhatsApp</a>
          <a class="button secondary" href={contact.instagram}>Instagram</a>
          <a class="button secondary" href={contact.github}>GitHub</a>
          <a class="button secondary" href={contact.gitlab}>GitLab</a>
        </div>
      </section>
    </main>
    <footer class="site-footer">
      <div>
        <strong>Muhammad Irham Rizq</strong>
        <span>Backend & DevOps Developer | Built with Astro</span>
      </div>
      <div>
        <a href={contact.github}>GitHub</a>
        <a href={contact.gitlab}>GitLab</a>
        <a href={contact.linkedin}>LinkedIn</a>
        <a href={contact.cv}>CV</a>
      </div>
    </footer>
    <script>
      const revealElements = document.querySelectorAll(".reveal");
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.16 }
      );

      revealElements.forEach((element) => revealObserver.observe(element));

      const filterButtons = document.querySelectorAll("[data-filter]");
      const projectCards = document.querySelectorAll("[data-categories]");

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const filter = button.getAttribute("data-filter");

          filterButtons.forEach((item) => {
            item.classList.toggle("active", item === button);
            item.setAttribute("aria-pressed", item === button ? "true" : "false");
          });

          projectCards.forEach((card) => {
            const categories = card.getAttribute("data-categories") || "";
            const isVisible = filter === "all" || categories.split(" ").includes(filter || "");
            card.toggleAttribute("hidden", !isVisible);
          });
        });
      });
    </script>
  </body>
</html>
